# ── LLM + vision ────────────────────────────────────────────────
NVIDIA_NIM_API_KEY=nvapi-...                # required: scriptwriter + vision judge
GROQ_API_KEY=                               # optional fallback LLM

# ── Footage providers ───────────────────────────────────────────
SHUTTERSTOCK_API_TOKEN=v2/...               # USER token from Shutterstock dashboard
SHUTTERSTOCK_CLIENT_ID=                     # optional (OAuth fallback)
SHUTTERSTOCK_CLIENT_SECRET=                 # optional
PEXELS_API_KEY=
PIXABAY_API_KEY=
COVERR_API_KEY=                             # optional

# ── Hostinger storage (FTP/FTPS) ────────────────────────────────
FTP_HOST=ftp.yourdomain.com
FTP_USER=u123456789
FTP_PASS=your_ftp_password
FTP_PORT=21                                 # 990 for implicit FTPS
FTP_USE_TLS=1                               # 1 = FTPS, 0 = plain FTP
FTP_BASE_DIR=/public_html/yt-agent
PUBLIC_BASE_URL=https://yourdomain.com/yt-agent

# ── Backend self-registration (Colab side) ──────────────────────
# PUBLIC_BACKEND_URL is filled automatically by the Colab notebook from
# the cloudflared tunnel; leave blank for local-dev runs.
PUBLIC_BACKEND_URL=
INSTANCE_ID=                                # auto-generated if blank
REGISTRY_FILENAME=registry.json
REGISTRY_HEARTBEAT_SECONDS=30
REGISTRY_STALE_AFTER_SECONDS=120

# Tier — frontend prefers gpu over cpu when multiple backends are online.
#   gpu = fast, on-demand (Colab)
#   cpu = slow, always-on (HuggingFace Space)
INSTANCE_TIER=gpu
INSTANCE_LABEL=

# ── Idle auto-shutdown (Colab compute budget guard) ─────────────
# After this many seconds with no jobs running AND no HTTP traffic,
# the backend deregisters from the registry, attempts to disconnect
# the Colab runtime, and exits. Set to 0 to disable (don't do that
# on Colab — you'll burn your free-tier hours overnight).
IDLE_TIMEOUT_SECONDS=600                    # 10 min
IDLE_CHECK_INTERVAL=30
IDLE_STARTUP_GRACE=300                      # don't auto-shutdown within 5 min of boot

# ── CORS (server-side) ──────────────────────────────────────────
# Extra origins beyond localhost + *.vercel.app. Comma-separated, no spaces.
ALLOWED_ORIGINS=

# ── YouTube upload (optional) ───────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secret.json
YOUTUBE_PRIVACY=public                      # public | unlisted | private
