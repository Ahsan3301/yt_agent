# ── Secrets / config ─────────────────────────────────────────
.env
.env.*
!.env.example
config/client_secret.json
Config/client_secret.json
config/youtube_token.json
Config/youtube_token.json

# ── Pipeline runtime artifacts ──────────────────────────────
output/
# Runtime log directories only — anchor at repo root so we don't
# swallow Next.js API route groups like web/app/api/runs/[id]/logs/.
# Bug: bare 'logs/' matched every 'logs/' in the tree, causing the
# runs/[id]/logs/route.ts endpoint to be silently ignored by git.
/logs/
/backend/logs/
/modules/logs/
data/run_state.json
data/used_clips.json
data/used_premises.json
data/used_premises_*.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ── Next.js / Node ───────────────────────────────────────────
web/node_modules/
web/.next/
web/out/
web/dist/
web/.turbo/
web/next-env.d.ts.bak
web/tsconfig.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Editors / OS ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ─────────────────────────────────────────────────────
*.log
tmp/
hf-space
yt_agent.zip
