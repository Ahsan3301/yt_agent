# YT Agent — Colab Secrets
#
# Add ONLY these in Colab's 🔑 Secrets panel. Everything else (NIM key,
# Shutterstock token, Pexels/Pixabay/Coverr keys, etc.) is managed in the
# dashboard's "API Keys" page and pulled from Firestore on startup.

# ── REQUIRED — Firebase service account (paste the whole JSON, multi-line) ─
GOOGLE_APPLICATION_CREDENTIALS_JSON   { "type": "service_account", "project_id": "...", "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ... }

# ── OPTIONAL — Cloudflare R2 (only if this backend will upload videos) ─
R2_ACCOUNT_ID                  4ca6ea8e30e4d1f1a23922fe674902e4
R2_ACCESS_KEY_ID               <from R2 API token>
R2_SECRET_ACCESS_KEY           <from R2 API token>
R2_BUCKET                      yt-agent
R2_PUBLIC_URL                  https://pub-xxxxxxxx.r2.dev

# ── OPTIONAL — Hostinger SFTP (archive overflow when R2 fills up) ─
SFTP_HOST                      82.180.138.116
SFTP_PORT                      65002
SFTP_USER                      u459456047
SFTP_PASS                      <your hostinger SSH password>
SFTP_BASE_DIR                  /home/u459456047/domains/<your-host>/public_html/yt-agent
PUBLIC_BASE_URL                https://<your-host>/yt-agent

# ── Tuning ──────────────────────────────────────────────────
R2_MAX_GB                      7              # migrate when R2 video bytes exceed this
INSTANCE_LABEL                 colab-gpu      # shown in the dashboard
INSTANCE_TIER                  gpu            # gpu = preferred, cpu = fallback
