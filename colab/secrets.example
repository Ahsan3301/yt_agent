# YT Agent — Colab Secrets to set
#
# Add each of these in the Colab 🔑 Secrets sidebar (left rail).
# Toggle "Notebook access" ON for each.

# ── Required ──────────────────────────────────────────────────
NVIDIA_NIM_API_KEY        nvapi-...
SHUTTERSTOCK_API_TOKEN    v2/...            # user token from Shutterstock dev console
PEXELS_API_KEY            ...
PIXABAY_API_KEY           ...

# ── FTP / Hostinger storage ──────────────────────────────────
FTP_HOST                  ftp.yourdomain.com
FTP_USER                  u123456789
FTP_PASS                  your_ftp_password
PUBLIC_BASE_URL           https://yourdomain.com/yt-agent

# ── Optional ─────────────────────────────────────────────────
COVERR_API_KEY            ...
SHUTTERSTOCK_CLIENT_ID    ...
SHUTTERSTOCK_CLIENT_SECRET ...
GROQ_API_KEY              gsk_...           # fallback LLM
FTP_BASE_DIR              /public_html/yt-agent
FTP_PORT                  21
FTP_USE_TLS               1                  # set to 0 for plain FTP

# ── Idle auto-shutdown (recommended on Colab) ────────────────
IDLE_TIMEOUT_SECONDS      600                # 10 min idle → release the GPU
IDLE_CHECK_INTERVAL       30
IDLE_STARTUP_GRACE        300                # 5-min grace after notebook start
