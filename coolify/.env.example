# ──────────────────────────────────────────────────────────────────
# yt-agent Coolify deployment — environment template.
#
# Copy this into Coolify's "Environment Variables" panel for the
# application. EVERY var below is required unless marked OPTIONAL.
#
# Don't commit a populated copy to git. The git-ignored .env file
# is for local docker-compose testing only.
# ──────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────
# Your custom domain — must point at this VPS via an A record.
# Caddy issues a Let's Encrypt cert for this on first request.
DOMAIN=your-domain.example.com

# ── Pocketbase ────────────────────────────────────────────────────
# First-boot admin user (idempotent — only created when admins table
# is empty). Pick a strong password; you'll log into /pb/_/ with it.
POCKETBASE_ADMIN_EMAIL=admin@your-domain.example.com
POCKETBASE_ADMIN_PASSWORD=change-me-to-something-strong

# Service token the Next.js API uses to call Pocketbase. Treat it like
# a database password. Generate with: openssl rand -hex 32
PB_SERVER_TOKEN=replace-with-openssl-rand-hex-32

# Public URL the browser uses to reach Pocketbase. Subpath-mounted so
# realtime SSE rides the same origin as the dashboard (no CORS).
NEXT_PUBLIC_PB_URL=/pb

# ── MinIO ─────────────────────────────────────────────────────────
# Bootstrap creds for the MinIO admin console (/minio/). Used by the
# dashboard's default S3 provider when no provider doc is configured.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=replace-with-openssl-rand-hex-24

# Default bucket name. minio-init creates it on first boot with a
# public-read policy so video URLs work without signed requests.
S3_BUCKET=yt-agent-videos

# Public base URL for video links. Must include the bucket name.
NEXT_PUBLIC_S3_PUBLIC_BASE=https://your-domain.example.com/s3/yt-agent-videos

# ── Storage provider credential encryption ───────────────────────
# Used to encrypt access_key/secret_access_key fields in the
# storage_providers Pocketbase collection. Generate with:
#   openssl rand -hex 32
# Once set, DO NOT change without re-keying every stored provider.
STORAGE_PROVIDERS_ENC_KEY=replace-with-openssl-rand-hex-32

# ── YouTube OAuth (required for uploads) ─────────────────────────
# From Google Cloud Console → APIs & Services → Credentials.
# Authorised redirect URI on the Google side MUST be:
#   https://your-domain.example.com/api/youtube/callback
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ── Optional OAuth providers ─────────────────────────────────────
# Leave blank to disable the one-click "Connect GitHub" etc. flows.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
HUGGINGFACE_OAUTH_CLIENT_ID=
HUGGINGFACE_OAUTH_CLIENT_SECRET=

# ── Cron + maintenance auth ──────────────────────────────────────
# Shared secret between the cron sidecar and the /api/maintenance/*
# routes. Generate with: openssl rand -hex 32
RENDER_TRIGGER_KEY=replace-with-openssl-rand-hex-32

# ── External launch URLs (shown in the dashboard) ────────────────
# Optional links to the user-facing notebooks. Leave blank to hide.
NEXT_PUBLIC_COLAB_URL=https://colab.research.google.com/github/Ahsan3301/yt_agent/blob/main/colab/yt_agent_colab.ipynb
NEXT_PUBLIC_HF_SPACE_URL=
