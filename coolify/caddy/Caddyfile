# Internal Caddy — sits BEHIND Coolify's Traefik.
#
# Traefik handles public TLS at the edge (Coolify auto-issues
# Let's Encrypt for the application domain). This Caddy listens on
# plain HTTP and does path-based routing only:
#   /pb/     → Pocketbase (admin UI + REST + realtime SSE)
#   /s3/     → MinIO S3 API (public video URLs, boto3)
#   /minio/  → MinIO admin console
#   /        → Next.js dashboard
#
# Routing on the same origin keeps cookies + CORS dead simple — the
# browser sees one domain, no preflight, no cross-origin auth.
#
# `{$DOMAIN}` resolves to:
#   - Coolify: SERVICE_FQDN_CADDY (e.g. yt-agent.thyker.online)
#   - Local: whatever you set as DOMAIN in your .env

{
	# Disable automatic HTTPS — Coolify's Traefik terminates TLS for us.
	auto_https off
	admin off
}

:80 {
	encode gzip zstd

	# ── Pocketbase: admin UI, REST, realtime SSE ──────────────
	handle_path /pb/* {
		reverse_proxy pocketbase:8090
	}

	# ── MinIO S3 API ──────────────────────────────────────────
	# NOTE the change from `handle_path /s3/*` (strips prefix) to
	# `handle /<bucket>/*` (no strip). AWS SigV4 signs the ENTIRE
	# URL path, so if Caddy strips /s3/ MinIO recomputes with a
	# different path → SignatureDoesNotMatch.
	#
	# Solution: expose MinIO at the bucket root of the SAME domain
	# without any prefix. Boto3 signs /<bucket>/<key>, sends to
	# /<bucket>/<key>, MinIO receives the same → signature validates.
	#
	# Downside: bucket names become part of the URL surface; can't
	# collide with dashboard routes (/api/, /pb/, /minio/, /_next/).
	# `yt-agent-videos` is safe.
	handle /yt-agent-videos/* {
		reverse_proxy minio:9000 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	# Back-compat — the old /s3/ path still resolves for any URLs
	# already stored in the DB pre-fix. Serves reads only; new writes
	# must use the bucket-root path.
	handle_path /s3/* {
		reverse_proxy minio:9000 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── MinIO admin console ───────────────────────────────────
	handle_path /minio/* {
		reverse_proxy minio:9001 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── Everything else → Next.js dashboard ───────────────────
	# OAuth callbacks (/api/youtube/callback etc.) land here.
	handle {
		reverse_proxy dashboard:3000
	}

	# Health endpoint Coolify can hit.
	respond /healthz 200 {
		body "ok"
		close
	}
}
