# Caddy config — single domain, subpath routing.
#
# Caddy auto-issues Let's Encrypt certs for {$DOMAIN} on first request.
# All four services live behind the same TLS cert so cookies + CORS
# stay simple.
#
# Path ordering matters: the more-specific /pb/ and /s3/ and /minio/
# matchers come first; the catch-all reverse_proxy to dashboard:3000
# is the fallback.

{$DOMAIN} {
	encode gzip zstd

	# ── Pocketbase: admin UI, REST, realtime SSE ──────────────
	# PB exposes /api, /_, /health on its root. We strip the /pb
	# prefix before forwarding so its routes work as-is.
	handle_path /pb/* {
		reverse_proxy pocketbase:8090
	}

	# ── MinIO S3 API: public video URLs + boto3 calls ─────────
	# Path-style addressing → /s3/<bucket>/<key> reaches MinIO as
	# /<bucket>/<key>. boto3 uses path-style when configured (see
	# backend/storage/providers/minio.py).
	handle_path /s3/* {
		reverse_proxy minio:9000 {
			# MinIO sometimes returns redirects pointing at its
			# internal hostname; rewrite the Host header so it
			# generates URLs with our public domain.
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── MinIO admin console ───────────────────────────────────
	handle_path /minio/* {
		reverse_proxy minio:9001 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# ── Everything else → Next.js dashboard ───────────────────
	# OAuth callbacks (/api/youtube/callback etc.) land here.
	handle {
		reverse_proxy dashboard:3000
	}

	# Health endpoint Coolify can hit
	respond /healthz 200 {
		body "ok"
		close
	}
}
