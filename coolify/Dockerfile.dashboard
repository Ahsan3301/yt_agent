# Multi-stage Next.js production image.
#
# Stage 1 (deps): install npm deps under /app/web/node_modules.
# Stage 2 (build): copy source + run `next build`. Produces .next/.
# Stage 3 (runner): slim Alpine image, copies only the build artefacts.
#
# Output mode: we rely on Next.js's `output: 'standalone'` setting
# (added to web/next.config.js as part of the migration) which produces
# a self-contained server.js + minimal node_modules under .next/standalone.
# That gets us a ~150 MB final image instead of ~800 MB.
#
# ARM target: node:20-alpine ships linux/arm64 — works on Oracle Ampere.
#
# Build context: PROJECT ROOT (not web/). compose.yml sets `context: ..`.

# ── Stage 1: deps ──────────────────────────────────────────────────
FROM node:20-alpine AS deps
WORKDIR /app/web

# Install only manifest first so the layer caches when deps don't change.
COPY web/package.json web/package-lock.json* ./
# CI-mode install: fail if lockfile out of sync; no postinstall scripts.
RUN npm ci --omit=dev=false --ignore-scripts

# ── Stage 2: build ─────────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app/web
COPY web/ .
COPY --from=deps /app/web/node_modules ./node_modules
# NEXT_PUBLIC_* env vars are inlined at build time — if we don't pass
# them here, any component that reads process.env.NEXT_PUBLIC_* gets
# an empty string at runtime. Pass through the ones the UI depends on.
ARG NEXT_PUBLIC_COLAB_URL=https://colab.research.google.com/github/Ahsan3301/yt_agent/blob/main/colab/yt_agent_colab.ipynb
ARG NEXT_PUBLIC_HF_SPACE_URL=
ARG NEXT_PUBLIC_PB_URL=/pb
ENV NEXT_PUBLIC_COLAB_URL=$NEXT_PUBLIC_COLAB_URL
ENV NEXT_PUBLIC_HF_SPACE_URL=$NEXT_PUBLIC_HF_SPACE_URL
ENV NEXT_PUBLIC_PB_URL=$NEXT_PUBLIC_PB_URL
RUN npm run build

# ── Stage 3: runner ────────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app/web

# Drop privileges. Next.js standalone needs read access to .next only.
RUN addgroup -g 1001 nodejs && adduser -u 1001 -G nodejs -s /bin/sh -D nextjs
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

# Standalone output bundles server.js + minimal node_modules. We also
# need .next/static (not included in standalone). public/ is optional —
# this project doesn't ship static assets, so we don't COPY it (would
# fail when the dir is absent). If you ever add web/public, restore:
#   COPY --from=builder --chown=nextjs:nodejs /app/web/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/web/.next/static ./.next/static

USER nextjs
EXPOSE 3000
# server.js is the standalone entry point Next.js generates.
CMD ["node", "server.js"]
